# ── Neon PostgreSQL (replace the URL below with your actual Neon connection string) ──
# Get it from: https://console.neon.tech → your project → Connection Details
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require

DATABASE_URL=postgresql+asyncpg://neondb_owner:YOURPASSWORD@ep-XXXX.us-east-1.aws.neon.tech/neondb?ssl=require
SYNC_DATABASE_URL=postgresql://neondb_owner:YOURPASSWORD@ep-XXXX.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-any-long-random-string-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Provider (pick one, fill its key) ──────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── OCR ───────────────────────────────────────────────────────────────────
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
USE_VISION_LLM=false

# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=SmartStore AI
LOG_LEVEL=INFO
